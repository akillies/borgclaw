# BorgClaw Configuration
# Copy this file to .env and fill in your values

# Required: Your Anthropic API key for Claude-powered agents
ANTHROPIC_API_KEY=your_key_here

# Hive secret — auto-generated on first Queen boot.
# Find it in data/hive-identity.json or Queen's first-boot output.
# Drones need this to join. Set via --secret flag, HIVE_SECRET env, or drone.json.
# HIVE_SECRET=your_hive_secret_here

# Ollama URL — local LLM inference endpoint
OLLAMA_URL=http://localhost:11434

# Queen's brain — she should think with the best model you have.
# Defaults to phi4-mini. Upgrade her when you pull a stronger model.
# QUEEN_MODEL=gemma3:27b
# QUEEN_MODEL=qwen3:8b
QUEEN_MODEL=phi4-mini

# Queen service port
QUEEN_PORT=9090

# BorgClaw home directory (defaults to current directory)
BORGCLAW_HOME=/path/to/borgclaw

# Knowledge base path — point to your personal AI OS or knowledge directory
# This is where BorgClaw looks for context files, entity registries, etc.
KNOWLEDGE_BASE_PATH=./knowledge

# NAS shared knowledge datastore — optional hive-wide knowledge layer.
# Mount your NAS (NFS/SMB/CIFS) and point here. All drones on the LAN
# that mount the same path share the same knowledge packs automatically.
# Leave unset if you have no NAS or prefer local-only knowledge.
# Example (NFS): mount -t nfs 192.168.1.10:/volume1/borgclaw /mnt/borgclaw-nas
# Example (SMB): mount -t cifs //192.168.1.10/borgclaw /mnt/borgclaw-nas
# NAS_MOUNT_PATH=/mnt/borgclaw-nas

# Sandbox — agent filesystem and network restrictions
# SANDBOX_ROOTS: colon-separated absolute paths agents may read/write.
# Defaults: $KNOWLEDGE_BASE_PATH, $BORGCLAW_HOME/data/, /tmp/borgclaw/
# Setting this overrides ALL defaults — list every root you need.
# SANDBOX_ROOTS=/path/to/knowledge:/path/to/borgclaw/data:/tmp/borgclaw

# SANDBOX_ALLOWED_DOMAINS: colon-separated domain patterns agents may fetch.
# Supports wildcard prefix: *.local matches any single-subdomain of .local
# Defaults: localhost, 127.0.0.1, ::1, *.local
# Setting this overrides ALL defaults.
# SANDBOX_ALLOWED_DOMAINS=localhost:*.local:api.example.com

# NATS server URL (for event coordination between Queen and nodes)
NATS_URL=nats://localhost:4222

# ntfy push notification URL (for approval notifications)
NTFY_URL=http://localhost:2586

# Optional: LiteLLM proxy URL (for multi-provider model routing)
LITELLM_URL=http://localhost:4000

# Tailscale auth key — generate at tailscale.com/admin/settings/keys
# Use an ephemeral key for disposable nodes, a reusable key for permanents.
# When set, the borgclaw-queen Tailscale container joins your tailnet on startup.
TAILSCALE_AUTH_KEY=
