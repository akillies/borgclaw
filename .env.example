# BorgClaw Configuration
# Copy this file to .env and fill in your values

# Required: Your Anthropic API key for Claude-powered agents
ANTHROPIC_API_KEY=your_key_here

# Hive secret — auto-generated on first Queen boot.
# Find it in data/hive-identity.json or Queen's first-boot output.
# Drones need this to join. Set via --secret flag, HIVE_SECRET env, or drone.json.
# HIVE_SECRET=your_hive_secret_here

# Ollama URL — local LLM inference endpoint
OLLAMA_URL=http://localhost:11434

# Queen service port
QUEEN_PORT=9090

# BorgClaw home directory (defaults to current directory)
BORGCLAW_HOME=/path/to/borgclaw

# Knowledge base path — point to your personal AI OS or knowledge directory
# This is where BorgClaw looks for context files, entity registries, etc.
KNOWLEDGE_BASE_PATH=./knowledge

# NATS server URL (for event coordination between Queen and nodes)
NATS_URL=nats://localhost:4222

# ntfy push notification URL (for approval notifications)
NTFY_URL=http://localhost:2586

# Optional: LiteLLM proxy URL (for multi-provider model routing)
LITELLM_URL=http://localhost:4000

# Tailscale auth key — generate at tailscale.com/admin/settings/keys
# Use an ephemeral key for disposable nodes, a reusable key for permanents.
# When set, the borgclaw-queen Tailscale container joins your tailnet on startup.
TAILSCALE_AUTH_KEY=
